{
  "name": "@kb-labs/agent-cli",
  "version": "0.6.0",
  "type": "module",
  "description": "CLI commands for KB Labs Agents V2. Provides agent:run-v2 command.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-manifest": {
      "import": "./dist/manifest.js",
      "types": "./dist/manifest.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "pretype-check": "pnpm --filter @kb-labs/agent-cli build",
    "clean": "rimraf dist",
    "build": "tsup --config tsup.config.ts && pnpm run build:studio",
    "build:cli": "tsup --config tsup.config.ts",
    "build:studio": "rspack build --config rspack.studio.config.mjs",
    "dev": "tsup --config tsup.config.ts --watch",
    "dev:studio": "rspack serve --config rspack.studio.config.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kb-labs/agent-contracts": "workspace:*",
    "@kb-labs/agent-core": "workspace:*",
    "@kb-labs/agent-history": "workspace:*",
    "@kb-labs/agent-kernel": "workspace:*",
    "@kb-labs/agent-runtime": "workspace:*",
    "@kb-labs/agent-sdk": "workspace:*",
    "@kb-labs/agent-store": "workspace:*",
    "@kb-labs/agent-tools": "workspace:*",
    "@kb-labs/agent-tracing": "workspace:*",
    "@kb-labs/sdk": "link:../../../../platform/kb-labs-sdk/packages/sdk",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@ant-design/icons": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "antd": "^5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "devDependencies": {
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit",
    "@kb-labs/plugin-runtime": "link:../../../../infra/kb-labs-plugin/packages/plugin-runtime",
    "@kb-labs/studio-plugin-tools": "link:../../../../platform/kb-labs-studio/packages/studio-plugin-tools",
    "@rspack/cli": "latest",
    "@rspack/core": "latest",
    "@types/node": "^24.3.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
